{
  "name": "@kehwar/skills",
  "type": "module",
  "version": "1.0.0",
  "description": "A personal collection of skills for AI coding agents",
  "author": "",
  "license": "MIT",
  "keywords": [
    "skills",
    "ai",
    "agents"
  ],
  "scripts": {
    "build": "tsx src/cli.ts build",
    "sync": "tsx src/cli.ts sync",
    "test": "vitest run",
    "upstream": "tsx src/cli.ts upstream",
    "check": "tsx src/cli.ts check",
    "clone-skills": "tsx src/cli.ts clone-skills",
    "opencode": "opencode web --hostname 0.0.0.0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:rules": "npx @eslint/config-inspector@2.0.1",
    "typecheck": "tsc --noEmit",
    "beads": "bd export --no-memories -o .beads/beads.jsonl && bv"
  },
  "dependencies": {
    "@npmcli/git": "^7.0.2",
    "citty": "^0.2.2",
    "effect": "^3.21.2",
    "simple-git": "^3.30.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@clack/prompts": "^1.3.0",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "jiti": "^2.7.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
